<Project Sdk="Microsoft.NET.Sdk">
    
  <PropertyGroup>
    <TargetFrameworks>$(PDFsharpTargetFrameworks_Library)</TargetFrameworks>
    <RootNamespace>PdfSharp</RootNamespace>
    <SignAssembly>True</SignAssembly>
    <AssemblyOriginatorKeyFile>..\..\..\..\..\StrongnameKey.snk</AssemblyOriginatorKeyFile>

    <!-- Removed IsAotCompatible/IsTrimmable because it causes problems with C# 14 Extension Anything code. -->
    <!--<IsTrimmable Condition="$([MSBuild]::IsTargetFrameworkCompatible('$(TargetFramework)', 'net6.0'))">true</IsTrimmable>-->
    <!--<IsAotCompatible Condition="$([MSBuild]::IsTargetFrameworkCompatible('$(TargetFramework)', 'net7.0'))">true</IsAotCompatible>-->
  </PropertyGroup>

  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release|AnyCPU'">
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
  </PropertyGroup>

  <ItemGroup>
    <!-- This file must be linked in all .NET Framework projects that use range expressions.
         Here it must be excluded because of InternalsVisibleTo.
    -->
    <Compile Remove="dotnet\GetSubArray.cs" />
  </ItemGroup>

  <ItemGroup>
    <Compile Condition="!Exists('Internal\SemVersionInformation-generated.cs')" Include="..\PdfSharp.BuildConfig\SemVersionInformation-substitute.cs" Link="SemVersionInformation-substitute.cs" />
  </ItemGroup>

  <ItemGroup>
    <!-- Using just PublicKeyToken does not work, but I cannot find out why.
         If somebody can explain or fix it, please write me.
         For now we use the whole public key instead.
    <InternalsVisibleTo Include="$(AssemblyName).Tests, PublicKeyToken=f94615aa0424f9eb" />
    <InternalsVisibleTo Include="$(AssemblyName).TestHelper, PublicKeyToken=f94615aa0424f9eb" />-->
    <InternalsVisibleTo Include="PdfSharp.System,              PublicKey=$(PDFsharpStronNamePublicKey)" />
    <InternalsVisibleTo Include="PdfSharp,                     PublicKey=$(PDFsharpStronNamePublicKey)" />
    <InternalsVisibleTo Include="PdfSharp-gdi,                 PublicKey=$(PDFsharpStronNamePublicKey)" />
    <InternalsVisibleTo Include="PdfSharp-wpf,                 PublicKey=$(PDFsharpStronNamePublicKey)" />
    <InternalsVisibleTo Include="PdfSharp.Imaging,             PublicKey=$(PDFsharpStronNamePublicKey)" />
    <InternalsVisibleTo Include="PdfSharp.OpenType,            PublicKey=$(PDFsharpStronNamePublicKey)" />
    <InternalsVisibleTo Include="PdfSharp.Charting,            PublicKey=$(PDFsharpStronNamePublicKey)" />
    <InternalsVisibleTo Include="PdfSharp.Charting.Graphics,   PublicKey=$(PDFsharpStronNamePublicKey)" />
    <InternalsVisibleTo Include="PdfSharp.Charting-gdi,        PublicKey=$(PDFsharpStronNamePublicKey)" />
    <InternalsVisibleTo Include="PdfSharp.Charting-wpf,        PublicKey=$(PDFsharpStronNamePublicKey)" />
    <InternalsVisibleTo Include="PdfSharp.Cryptography,        PublicKey=$(PDFsharpStronNamePublicKey)" />
    <InternalsVisibleTo Include="PdfSharp.BarCodes,            PublicKey=$(PDFsharpStronNamePublicKey)" />
    <InternalsVisibleTo Include="PdfSharp.BarCodes-gdi,        PublicKey=$(PDFsharpStronNamePublicKey)" />
    <InternalsVisibleTo Include="PdfSharp.BarCodes-wpf,        PublicKey=$(PDFsharpStronNamePublicKey)" />
    <InternalsVisibleTo Include="MigraDoc.DocumentObjectModel, PublicKey=$(PDFsharpStronNamePublicKey)" />
    <InternalsVisibleTo Include="MigraDoc.Rendering,           PublicKey=$(PDFsharpStronNamePublicKey)" />
    <InternalsVisibleTo Include="MigraDoc.Rendering-gdi,       PublicKey=$(PDFsharpStronNamePublicKey)" />
    <InternalsVisibleTo Include="MigraDoc.Rendering-wpf,       PublicKey=$(PDFsharpStronNamePublicKey)" />
    <InternalsVisibleTo Include="MigraDoc.RtfRendering,        PublicKey=$(PDFsharpStronNamePublicKey)" />
    <InternalsVisibleTo Include="MigraDoc.RtfRendering-gdi,    PublicKey=$(PDFsharpStronNamePublicKey)" />
    <InternalsVisibleTo Include="MigraDoc.RtfRendering-wpf,    PublicKey=$(PDFsharpStronNamePublicKey)" />
    <InternalsVisibleTo Include="PdfSharp.Quality,             PublicKey=$(PDFsharpStronNamePublicKey)" />
    <InternalsVisibleTo Include="PdfSharp.Quality-gdi,         PublicKey=$(PDFsharpStronNamePublicKey)" />
    <InternalsVisibleTo Include="PdfSharp.Quality-wpf,         PublicKey=$(PDFsharpStronNamePublicKey)" />
    <!--<InternalsVisibleTo Include="PdfSharp.System,              PublicKey=$(PDFsharpStronNamePublicKey)" />-->
    <InternalsVisibleTo Include="PdfSharp.Shared-gdi,          PublicKey=$(PDFsharpStronNamePublicKey)" />
    <InternalsVisibleTo Include="PdfSharp.Shared-wpf,          PublicKey=$(PDFsharpStronNamePublicKey)" />
    <InternalsVisibleTo Include="PdfSharp.TestHelper,          PublicKey=$(PDFsharpStronNamePublicKey)" />
    <InternalsVisibleTo Include="PdfSharp.TestHelper-gdi,      PublicKey=$(PDFsharpStronNamePublicKey)" />
    <InternalsVisibleTo Include="PdfSharp.TestHelper-wpf,      PublicKey=$(PDFsharpStronNamePublicKey)" />
    <InternalsVisibleTo Include="PdfSharp.Tests,               PublicKey=$(PDFsharpStronNamePublicKey)" />
    <InternalsVisibleTo Include="PdfSharp.Tests-gdi,           PublicKey=$(PDFsharpStronNamePublicKey)" />
    <InternalsVisibleTo Include="PdfSharp.Tests-wpf,           PublicKey=$(PDFsharpStronNamePublicKey)" />
    <InternalsVisibleTo Include="Shared.Tests,                 PublicKey=$(PDFsharpStronNamePublicKey)" />
    <InternalsVisibleTo Include="MigraDoc.Tests,               PublicKey=$(PDFsharpStronNamePublicKey)" />
    <InternalsVisibleTo Include="MigraDoc.Tests-gdi,           PublicKey=$(PDFsharpStronNamePublicKey)" />
    <InternalsVisibleTo Include="MigraDoc.Tests-wpf,           PublicKey=$(PDFsharpStronNamePublicKey)" />
