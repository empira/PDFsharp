  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" />
    <PackageReference Include="System.Security.Cryptography.Pkcs" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\..\shared\src\PdfSharp.Shared\PdfSharp.Shared.csproj" />
    <ProjectReference Include="..\..\..\shared\src\PdfSharp.System\PdfSharp.System.csproj" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="PdfSharp.Tests,      PublicKey=$(PDFsharpStronNamePublicKey)" />
    <InternalsVisibleTo Include="PdfSharp.TestHelper, PublicKey=$(PDFsharpStronNamePublicKey)" />
  </ItemGroup>

</Project>
